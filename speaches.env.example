# Copy this file to speaches.env, then edit YOUR_PC_LAN_IP if you want phone/LAN access.
#
# Gemini mode:
# - Keep CHAT_COMPLETION_BASE_URL commented out.
# - Speaches handles STT and TTS locally.
# - The browser sends text to Gemini after Speaches transcribes audio.
#
# Local Ollama mode:
# - Uncomment CHAT_COMPLETION_BASE_URL below.
# - Make sure Ollama is running on the host machine.

# CHAT_COMPLETION_BASE_URL=http://host.docker.internal:11434/v1
LOOPBACK_HOST_URL=http://localhost:8000
ALLOW_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://YOUR_PC_LAN_IP:5173","https://localhost:5173","https://127.0.0.1:5173","https://YOUR_PC_LAN_IP:5173"]
